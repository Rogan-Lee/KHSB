# ============================================================
# 환경 변수 설정 가이드 — study-room-manager
# 새 시설 배포 시 이 파일을 복사하여 .env.local 로 저장하세요
# ============================================================

# ── Neon Serverless Postgres ──────────────────────────────
# Neon 대시보드 → Project → Connection String (Pooled)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Clerk Auth ────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Clerk redirect URLs (기본값 사용 가능)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# ── App URL ───────────────────────────────────────────────
# 로컬: http://localhost:3000 / 프로덕션: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Groq AI (멘토링 리포트 자동 작성) ───────────────────────
# https://console.groq.com → API Keys
# 선택사항 — 없으면 AI 기능 비활성화됨
GROQ_API_KEY=gsk_xxx

# ── Kakao (학부모 메시지 / 카카오 로그인) ────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키
NEXT_PUBLIC_KAKAO_JS_KEY=xxx                    # JavaScript 키
KAKAO_REST_API_KEY=xxx                          # REST API 키
KAKAO_CLIENT_SECRET=xxx                         # (선택) 보안 강화 시 설정
KAKAO_REDIRECT_URI=http://localhost:3000/api/kakao/callback

# ── Google OAuth (캘린더 / 시트 연동) ─────────────────────────
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보
# 선택사항 — 없으면 Google 연동 기능 비활성화됨
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-calendar/callback

# ── Vercel Blob (파일 업로드) ─────────────────────────────────
# Vercel 대시보드 → Storage → Blob → 토큰 생성
# 선택사항 — 없으면 이미지 업로드 기능 비활성화됨
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# ── Slack (운영 알림) ───────────────────────────────────────
# Slack 앱 → Incoming Webhooks → Webhook URL 생성
# 선택사항 — 없으면 Slack 알림 비활성화됨
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
