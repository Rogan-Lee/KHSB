generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN       // 시스템 최상위 관리자 (다계정 가능)
  ADMIN             // (deprecated) 이전 버전 호환, 신규 생성 금지
  DIRECTOR          // 원장
  MENTOR            // 오프라인 자습실 멘토
  STAFF
  STUDENT
  CONSULTANT        // 온라인 관리 — 컨설턴트 (입시/수행평가 설계)
  MANAGER_MENTOR    // 온라인 관리 — 관리 멘토 (진도/계획/카톡 로그)
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  WITHDRAWN    // 퇴원
}

enum AttendanceType {
  NORMAL
  ABSENT
  TARDY
  EARLY_LEAVE
  APPROVED_ABSENT
  NOTIFIED_ABSENT
}

enum MeritType {
  MERIT
  DEMERIT
}

enum MentoringStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum ConsultationStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ConsultationType {
  STUDENT       // 학생 상담
  PARENT        // 학부모 상담
}

enum ConsultationCategory {
  ENROLLED      // 재원생
  NEW_ADMISSION // 신규 입실
  CONSIDERING   // 등록 고민
}

enum ConsultationOwner {
  DIRECTOR      // 원장 면담
  HEAD_TEACHER  // 책임T 면담
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

enum MessageType {
  ATTENDANCE
  ABSENT
  MERIT_DEMERIT
  MENTORING
  MONTHLY_REPORT
  CONSULTATION
  CUSTOM
}

enum CommunicationType {
  PARENT_REQUEST  // 학부모 요청사항
  STAFF_NOTE      // 운영진 전달사항
}

enum ExamType {
  OFFICIAL_MOCK   // 공식 모의고사 (수능/평가원)
  PRIVATE_MOCK    // 사설 모의고사
  SCHOOL_EXAM     // 학교 내신
}

enum CalendarEventType {
  SCHOOL_EXAM    // 학교 시험
  SCHOOL_EVENT   // 학교 행사
  PERSONAL       // 개인 일정
  PLATFORM       // 플랫폼 일정
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String
  clerkId    String?     @unique
  role       Role        @default(MENTOR)
  isMentor   Boolean     @default(false)
  students        Student[]        @relation("MentorStudents")
  onlineStudents     Student[]     @relation("OnlineManagerStudents")  // MANAGER_MENTOR 담당 온라인 학생
  consultingStudents Student[]     @relation("ConsultantStudents")     // CONSULTANT 담당 온라인 학생
  mentorings      Mentoring[]
  mentorSchedules MentorSchedule[]
  parentReports   ParentReport[]
  timetableEntries TimetableEntry[]
  announcements    Announcement[]
  workTags        WorkTag[]
  payrollSetting  PayrollSetting?
  payrollRecords  PayrollRecord[]
  kakaoAccessToken  String?
  kakaoRefreshToken String?
  kakaoTokenExpiry  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum WorkTagType {
  CLOCK_IN
  CLOCK_OUT
}

model WorkTag {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       WorkTagType
  taggedAt   DateTime    @default(now())
  note       String?
  // 관리자 편집 흔적
  editedById   String?
  editedByName String?
  editedAt     DateTime?
  createdAt  DateTime    @default(now())

  @@index([userId, taggedAt])
  @@index([taggedAt])
}

model PayrollSetting {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hourlyRate       Int                          // 원
  weeklyHolidayPay Boolean  @default(true)      // 주휴수당 지급 여부
  note             String?
  updatedById      String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model PayrollRecord {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year              Int
  month             Int
  workMinutes       Int
  baseWage          Int                         // 기본급 (시급×시간)
  weeklyHolidayWage Int      @default(0)        // 주휴수당 합계
  totalWage         Int                         // baseWage + weeklyHolidayWage
  hourlyRateAtCalc  Int                         // 계산 시점 시급 (이력 보존)
  calculatedAt      DateTime @default(now())

  @@unique([userId, year, month])
  @@index([year, month])
}

model Student {
  id                  String                 @id @default(cuid())
  name                String
  phone               String?
  parentPhone         String
  parentEmail         String?
  grade               String
  school              String?
  classGroup          String?               // 반 (예: 정규반, 선택반)
  seat                String?
  startDate           DateTime
  endDate             DateTime?
  birthDate           DateTime?              @db.Date // 생년월일 (핀번호/수험표용)
  status              StudentStatus          @default(ACTIVE)
  internalScoreRange  String?               // 내신 성적대 (예: "2~3등급")
  mockScoreRange      String?               // 모의고사 성적대 (예: "3~4등급")
  targetUniversity    String?               // 희망 대학
  mentoringNotes      String?               // 멘토링 주의사항
  dailyNote           String?               // 당일 변동 사항 (매일 00시 KST 기준 초기화)
  dailyNoteDate       DateTime? @db.Date    // 당일 변동 기록 날짜 (조회 시 오늘이 아니면 표시 안함)
  studentInfo         String?               // 학생정보 (추가 메모)
  selectedSubjects    String?               // 선택과목 (예: "수학, 영어, 사탐")
  admissionType       String?               // 대학 입시 전형 (예: "수시 학종, 정시")
  onlineLectures      String?               // 수강중인 인강 (예: "메가스터디 수학")
  changeNote          String?               // 추후 변동 예정 사항
  vocabTestDate       DateTime? @db.Date    // 영단어 테스트 일자 (매주 화요일 초기화)
  pledgeDate          DateTime? @db.Date    // 서약서 제출 일자 (최초 1회 영구 보존)
  mockAnalysisDate    DateTime? @db.Date    // 모의고사 분석지 일자
  schoolAnalysisDate  DateTime? @db.Date    // 내신 분석지 일자
  plannerSentDate     DateTime? @db.Date    // 플래너 전송 일자 (매주 화요일 초기화)
  weeklyPlanDate      DateTime? @db.Date    // 주간 공부계획 일자 (매주 화요일 초기화)
  mentorId            String?
  mentor              User?                  @relation("MentorStudents", fields: [mentorId], references: [id])
  // ─── 온라인 관리 모듈 (Phase 1) ───
  isOnlineManaged      Boolean                @default(false)
  onlineStartedAt      DateTime?
  assignedMentorId     String?                // MANAGER_MENTOR
  assignedMentor       User?                  @relation("OnlineManagerStudents", fields: [assignedMentorId], references: [id])
  assignedConsultantId String?                // CONSULTANT
  assignedConsultant   User?                  @relation("ConsultantStudents", fields: [assignedConsultantId], references: [id])
  magicLinks           StudentMagicLink[]
  // ─────────────────────────────────
  schedules      AttendanceSchedule[]
  attendances    AttendanceRecord[]
  outings        OutingSchedule[]
  dailyOutings   DailyOuting[]
  merits         MeritDemerit[]
  mentorings     Mentoring[]
  academicPlans  AcademicPlan[]
  parentReports  ParentReport[]
  consultations  DirectorConsultation[]
  messages       MessageLog[]
  monthlyReports MonthlyReport[]
  monthlyAwards  MonthlyAward[]
  communications Communication[]
  examScores     ExamScore[]
  calendarEvents CalendarEvent[]
  assignments      Assignment[]
  timetableEntries TimetableEntry[]
  dailyPlans       DailyPlan[]
  studyPlanReports StudyPlanReport[]
  monthlyNotes     MonthlyNote[]
  vocabEnrollment  VocabTestEnrollment?
  vocabScores      VocabTestScore[]
  examSeatAssignments ExamSeatAssignment[]
  photos           Photo[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([isOnlineManaged, status])
  @@index([assignedMentorId])
  @@index([assignedConsultantId])
}

// 온라인 학생 포털(`/s/[token]`) 접근용 매직링크.
// 로그인 없이 토큰만으로 학생 본인 식별. 만료/무효화 지원.
model StudentMagicLink {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  token          String    @unique @default(cuid())
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  lastAccessedAt DateTime?
  accessCount    Int       @default(0)
  issuedById     String?   // User.id — 발급자(원장 등)

  @@index([studentId, revokedAt])
  @@index([expiresAt])
}

model AttendanceSchedule {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=일, 1=월, ..., 6=토
  startTime String // "09:00"
  endTime   String // "22:00"
  createdAt DateTime @default(now())
}

model AttendanceRecord {
  id           String         @id @default(cuid())
  studentId    String
  student      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date         DateTime       @db.Date
  checkIn      DateTime?
  checkOut     DateTime?
  outStart     DateTime?      // 실제 외출 시각
  outEnd       DateTime?      // 실제 복귀 시각
  type         AttendanceType @default(NORMAL)
  notes        String?
  isAutoClosed Boolean        @default(false) // 자정 크론에서 자동 퇴실 처리됨
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([studentId, date])
  @@index([date])
}

model OutingSchedule {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0=일, 1=월, ..., 6=토
  outStart  String   // "12:00" - 예정 외출 시각
  outEnd    String   // "14:00" - 예정 복귀 시각
  reason    String?  // "수학학원"
  createdAt DateTime @default(now())
}

model DailyOuting {
  id        String    @id @default(cuid())
  studentId String
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  outStart  DateTime?
  outEnd    DateTime?
  reason    String?
  createdAt DateTime  @default(now())

  @@index([studentId, date])
}

model MeritDemerit {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  type        MeritType
  points      Int
  reason      String
  category    String?
  createdById String
  createdAt   DateTime  @default(now())

  @@index([studentId, date])
  @@index([date])
}

model Mentoring {
  id                 String          @id @default(cuid())
  studentId          String
  student            Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentorId           String
  mentor             User            @relation(fields: [mentorId], references: [id])
  scheduledAt        DateTime
  scheduledTimeStart String?         // "14:00"
  scheduledTimeEnd   String?         // "15:00"
  actualDate         DateTime?
  actualStartTime    String?         // "14:05"
  actualEndTime      String?         // "15:10"
  status             MentoringStatus @default(SCHEDULED)
  content            String?         // 오늘 멘토링 내용
  previousIssues     String?         // 이전 회차에서 전달한 내용
  improvements       String?         // 개선된 점
  weaknesses         String?         // 부족한 점
  nextGoals          String?         // 다음 멘토링 목표
  notes              String?         // 기타 메모
  feedbackSentAt     DateTime?       // 피드백 이메일 발송 시각
  parentReports      ParentReport[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([studentId, scheduledAt])
  @@index([mentorId, scheduledAt])
  @@index([status, scheduledAt])
}

model MentorSchedule {
  id        String   @id @default(cuid())
  mentorId  String
  mentor    User     @relation(fields: [mentorId], references: [id])
  dayOfWeek Int      // 0=일, 1=월, ..., 6=토
  timeStart String   // "14:00"
  timeEnd   String   // "18:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mentorId, dayOfWeek])
}

model AcademicPlan {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  weeklyGoals Json?
  subjects    Json?
  overallGoal String?
  reflection  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, year, month])
}

model DirectorConsultation {
  id            String             @id @default(cuid())
  studentId     String?
  student       Student?           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  prospectName  String?            // 미등록(신규 상담) 원생 이름
  prospectGrade String?            // 미등록 원생 학년
  prospectPhone String?            // 미등록 원생 연락처
  type          ConsultationType   @default(STUDENT)
  category      ConsultationCategory @default(ENROLLED)
  owner         ConsultationOwner  @default(DIRECTOR)
  scheduledAt   DateTime?
  actualDate    DateTime?
  status        ConsultationStatus @default(SCHEDULED)
  agenda        String?
  notes         String?
  outcome       String?
  followUp      String?
  reports       ConsultationReport[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model MessageLog {
  id            String        @id @default(cuid())
  studentId     String
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          MessageType
  recipient     String
  recipientName String?
  content       String
  sentAt        DateTime      @default(now())
  status        MessageStatus @default(PENDING)
  errorMsg      String?
}

model MonthlyReport {
  id                    String    @id @default(cuid())
  studentId             String
  student               Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  year                  Int
  month                 Int
  attendanceDays        Int       @default(0)
  absentDays            Int       @default(0)
  tardyCount            Int       @default(0)
  earlyLeaveCount       Int       @default(0)
  totalMerits           Int       @default(0)
  totalDemerits         Int       @default(0)
  mentoringCount        Int       @default(0)
  // 월간 학부모 리포트 추가 필드
  totalStudyMinutes     Int       @default(0)   // 월간 총 순공 시간 (분)
  prevMonthStudyMinutes Int?                    // 전월 순공 시간 (비교용)
  studyRankInRoom       Int?                    // 독서실 내 순위
  studyRankTotal        Int?                    // 전체 인원 수
  gradeAvgMinutes       Int?                    // 같은 학년 평균 순공 시간
  outingCount           Int       @default(0)   // 외출 횟수
  totalOutingMinutes    Int       @default(0)   // 총 외출 시간 (분)
  mentoringSummary      String?                 // 월간 멘토링 종합 의견
  overallComment        String?                 // (기존) 전체 코멘트
  shareToken            String?   @unique       // 학부모 공유 토큰
  attachedPhotoIds      String[]  @default([])  // 자동 첨부된 Photo ID 목록 (최신 N장)
  sentAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([studentId, year, month])
}

// 월별 입시 정보 (모든 학생 공통, 관리자가 매월 작성)
model MonthlyAdmissionInfo {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  grade     String?                  // null = 전체, 특정 학년만 대상
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, grade])
}

// 이달의 시상 (태도 우수자/멘토 선정 우수자 등)
model MonthlyAward {
  id          String   @id @default(cuid())
  year        Int
  month       Int
  category    String                   // "ATTITUDE" | "MENTOR_PICK" | "IMPROVEMENT"
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  description String?
  createdAt   DateTime @default(now())

  @@index([year, month])
}

model Communication {
  id            String            @id @default(cuid())
  studentId     String
  student       Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type          CommunicationType
  content       String
  isChecked     Boolean           @default(false)
  checkedAt     DateTime?
  createdById   String
  createdByName String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ExamScore {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examType    ExamType
  examName    String
  examDate    DateTime  @db.Date
  subject     String
  rawScore    Int?
  grade       Int?
  percentile  Float?
  notes       String?
  sessionId   String?
  session     ExamSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sessionId])
}

model ExamSession {
  id          String   @id @default(cuid())
  title       String                        // 예: "2026년 4월 시스모의고사"
  examDate    DateTime @db.Date
  room        String   @default("H")        // "H" | "K"
  examType    ExamType @default(OFFICIAL_MOCK)
  subjects    String[]                      // ["국어","수학","영어","탐구1","탐구2"]
  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ExamSeatAssignment[]
  scores      ExamScore[]

  @@index([examDate])
}

model PhotoFolder {
  id        String        @id @default(cuid())
  name      String
  parentId  String?
  parent    PhotoFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  PhotoFolder[] @relation("FolderTree")
  photos    Photo[]
  // 연/월 자동 폴더 여부 — auto=true 면 YYYY/MM 자동, 수동 폴더는 false
  isAuto    Boolean       @default(false)
  autoKey   String?       @unique  // "2026/04" 같은 자동 폴더 식별 키 (중복 방지)
  createdById String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([parentId])
}

model Photo {
  id            String       @id @default(cuid())
  folderId      String?
  folder        PhotoFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  fileName      String       // 원본 파일명 (중복 시 (1), (2) suffix 포함)
  url           String       // 원본 blob URL
  thumbnailUrl  String?      // 썸네일 blob URL (sharp 생성)
  mimeType      String
  sizeBytes     Int
  parsedDate    DateTime?    @db.Date  // 파일명 파싱 결과
  parsedSeatNumber Int?                // 파일명 파싱 결과
  parsedName    String?                // 파일명 파싱 결과
  studentId     String?
  student       Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  uploadedById  String
  uploadedByName String
  uploadedAt    DateTime     @default(now())

  @@index([folderId])
  @@index([parsedDate])
  @@index([parsedSeatNumber])
  @@index([studentId])
}

model ExamSeatAssignment {
  id         String      @id @default(cuid())
  sessionId  String
  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seatNumber Int
  studentId  String
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([sessionId, seatNumber])
  @@unique([sessionId, studentId])
  @@index([studentId])
}

model Assignment {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentoringId   String?   // 연결된 멘토링 세션 (optional)
  title         String    // 과제 제목
  description   String?   // 상세 내용
  subject       String?   // 과목 (수학, 영어, 국어 등)
  dueDate       DateTime? @db.Date  // 마감일
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedNote String?   // 완료 메모
  createdById   String
  createdByName String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarEvent {
  id            String            @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  allDay        Boolean           @default(true)
  type          CalendarEventType
  studentId     String?
  student       Student?          @relation(fields: [studentId], references: [id], onDelete: SetNull)
  schoolName    String?
  color         String?
  googleEventId String?
  createdById   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ParentReport {
  id              String    @id @default(cuid())
  token           String    @unique @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  mentoringId     String?
  mentoring       Mentoring? @relation(fields: [mentoringId], references: [id], onDelete: SetNull)
  studyPlanNote   String?     // 학습 계획 메모 (텍스트)
  studyPlanImages String[]    // 학습 계획 이미지 URL 목록
  customNote      String?     // 학부모께 전달할 메시지
  createdById     String
  createdBy       User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
}

model TimetableEntry {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dayOfWeek   Int      // 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat, 0=Sun
  startTime   String   // "HH:MM"
  endTime     String   // "HH:MM"
  subject     String
  details     String?
  colorCode   String   @default("blue")
  allDay      Boolean  @default(false)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyPlan {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  items     Json     @default("[]") // [{ id, text, done, colorCode, duration? }]
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudyPlanReport {
  id          String   @id @default(cuid())
  token       String   @unique @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  images      String[]
  createdById String
  createdAt   DateTime @default(now())
}

model ConsultationReport {
  id               String              @id @default(cuid())
  token            String              @unique @default(cuid())
  consultationId   String
  consultation     DirectorConsultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  content          String              // AI 생성 팔로업 메시지 본문
  recipientName    String?
  createdById      String
  createdAt        DateTime            @default(now())
}

enum VocabEnrollReason {
  AUTO_GRADE3       // 고3 영어 3등급 이하 자동
  PARENT_REQUEST    // 학부모 신청
  MENTOR_ASSIGNED   // 멘토 지정
  CUSTOM            // 기타
}

model VocabTestEnrollment {
  id           String            @id @default(cuid())
  studentId    String
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reason       VocabEnrollReason @default(CUSTOM)
  isActive     Boolean           @default(true)
  enrolledById String
  enrolledAt   DateTime          @default(now())
  unenrolledAt DateTime?

  @@unique([studentId])
}

model VocabTestScore {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  testDate     DateTime @db.Date
  totalWords   Int
  correctWords Int
  score        Float    // 백분율 (correctWords / totalWords * 100)
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
}

enum HandoverPriority {
  URGENT  // 긴급
  NORMAL  // 일반
}

enum ShiftType {
  OPEN   // 오픈 전용
  CLOSE  // 마감 전용
  ALL    // 공통
}

model ChecklistTemplate {
  id        String    @id @default(cuid())
  title     String
  shiftType ShiftType @default(ALL)
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model HandoverTask {
  id           String    @id @default(cuid())
  handoverId   String
  handover     Handover  @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  title        String
  content      String    @default("")
  assigneeId   String?
  assigneeName String?
  order        Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
}

model HandoverChecklist {
  id            String    @id @default(cuid())
  handoverId    String
  handover      Handover  @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  templateId    String?
  title         String
  shiftType     String    @default("ALL")
  isChecked     Boolean   @default(false)
  checkedAt     DateTime?
  checkedById   String?
  checkedByName String?
  order         Int       @default(0)
}

model MonthlyNote {
  id          String   @id @default(cuid())
  year        Int
  month       Int
  studentId   String?
  student     Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentName String
  content     String
  authorId    String
  authorName  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year, month])
}

model Handover {
  id                   String              @id @default(cuid())
  date                 DateTime            @db.Date
  content              String              @default("") // 당일 근무 내용
  priority             HandoverPriority    @default(NORMAL)
  category             String?
  isPinned             Boolean             @default(false)
  authorId             String
  authorName           String
  recipientId          String?             // 수신 담당자 ID
  recipientName        String?             // 수신 담당자 이름
  tasks                HandoverTask[]
  checklist            HandoverChecklist[]
  monthlyNotesSnapshot Json?
  reads                HandoverRead[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([date])
}

model HandoverRead {
  id         String   @id @default(cuid())
  handoverId String
  handover   Handover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  userId     String
  userName   String
  readAt     DateTime @default(now())

  @@unique([handoverId, userId])
}

model Todo {
  id             String        @id @default(cuid())
  title          String
  content        String?
  dueDate        DateTime?     @db.Date
  priority       String        @default("NORMAL") // URGENT, HIGH, NORMAL, LOW
  isCompleted    Boolean       @default(false)
  completedAt    DateTime?
  authorId       String
  authorName     String
  assigneeId     String?
  assigneeName   String?
  category       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  // 마지막 편집 메타 (목록에서 빠른 표시용 역정규화)
  lastEditorId   String?
  lastEditorName String?
  lastEditedAt   DateTime?
  versions       TodoVersion[]

  @@index([authorId])
  @@index([assigneeId])
}

// Todo 수정 이력. v1 = 최초 등록 스냅샷. 이후 수정 전 상태를 순차 저장.
model TodoVersion {
  id           String    @id @default(cuid())
  todoId       String
  todo         Todo      @relation(fields: [todoId], references: [id], onDelete: Cascade)
  version      Int       // 1부터 증분
  title        String
  content      String?
  dueDate      DateTime? @db.Date
  priority     String
  assigneeId   String?
  assigneeName String?
  category     String?
  editorId     String
  editorName   String
  createdAt    DateTime  @default(now())

  @@unique([todoId, version])
  @@index([todoId])
}

model MeetingMinutes {
  id         String               @id @default(cuid())
  title      String
  date       DateTime             @db.Date
  content    String               @default("")
  attendees  String[]             // 참석자 이름 목록
  team       String               @default("운영팀")  // "멘토링팀" | "운영팀" | "면담"
  // 열람 제한. 빈 배열 = 공개(기존 동작).
  // 값이 있으면 해당 user.id + 작성자 + DIRECTOR/SUPER_ADMIN 만 열람 가능.
  visibleTo  String[]             @default([])
  authorId   String
  authorName String
  reads      MeetingMinutesRead[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@index([date])
  @@index([team])
}

model MeetingMinutesRead {
  id               String         @id @default(cuid())
  meetingMinutesId String
  meetingMinutes   MeetingMinutes @relation(fields: [meetingMinutesId], references: [id], onDelete: Cascade)
  userId           String
  userName         String
  readAt           DateTime       @default(now())

  @@unique([meetingMinutesId, userId])
}

enum RequestStatus {
  PENDING     // 대기
  IN_PROGRESS // 진행중
  DONE        // 완료
  ON_HOLD     // 보류
}

enum RequestCategory {
  BUG         // 버그
  FEATURE     // 기능요청
  IMPROVEMENT // 개선
}

enum RequestPriority {
  URGENT // 긴급
  NORMAL // 일반
}

model FeatureRequest {
  id          String          @id @default(cuid())
  title       String
  description String?         // 마크다운
  status      RequestStatus   @default(PENDING)
  category    RequestCategory @default(FEATURE)
  priority    RequestPriority @default(NORMAL)
  relatedPage String?         // 관련 페이지 slug
  requester   String?         // 요청자 (카톡으로 보낸 사람)
  authorId    String
  authorName  String
  comments    FeatureRequestComment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
}

model FeatureRequestComment {
  id               String         @id @default(cuid())
  content          String
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  authorId         String
  authorName       String
  authorRole       String         // 역할 배지 표시용
  createdAt        DateTime       @default(now())

  @@index([featureRequestId])
}

// Google Sheets 연동 설정 (싱글톤, id="singleton")
model GoogleSheetsConfig {
  id        String   @id @default("singleton")
  sheetUrl  String   // Google Sheets 전체 URL
  sheetName String?  // 시트(탭) 이름 — null이면 첫 번째 시트
  updatedAt DateTime @updatedAt
}

// Google Calendar OAuth 토큰 저장 (싱글톤, id="singleton")
model GoogleCalendarToken {
  id           String   @id @default("singleton")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String   @default("primary")
  connectedBy  String   // 연동한 사용자 이름
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String   @default("")
  content   String   @db.Text
  page      String   @default("mentoring")
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
